  <property name="styleSheet">
   <string notr="true">QPushButton {
    background-color: #1565c0;
    color: white;
    border-radius: 6px;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: bold;
    min-height: 34px;
}
QPushButton:hover { background-color: #0d47a1; }
QPushButton#btnAracSil { background-color: #c62828; }
QPushButton#btnAracSil:hover { background-color: #b71c1c; }
QPushButton#btnBakimEkle { background-color: #1565c0; }
QPushButton#btnBakimEkle:hover { background-color: #0d47a1; }
QPushButton#btnBakimdenCikar { background-color: #c62828; }
QPushButton#btnBakimdenCikar:hover { background-color: #b71c1c; }
QPushButton#btnKiralamaKapat { background-color: #c62828; }
QPushButton#btnKiralamaKapat:hover { background-color: #b71c1c; }
QTableWidget {
    border: 1px solid #b0bec5;
    gridline-color: #eceff1;
    background-color: white;
    selection-background-color: #bbdefb;
    alternate-background-color: #f5f5f5;
}
QTableWidget::item { padding: 4px; }
QHeaderView::section {
    background-color: #1565c0;
    color: white;
    padding: 6px;
    font-weight: bold;
    border: none;
}
QTabWidget::pane { border: 1px solid #b0bec5; background-color: white; }
QTabBar::tab {
    background-color: #e3f2fd;
    color: #1565c0;
    padding: 10px 24px;
    font-weight: bold;
    border: 1px solid #b0bec5;
    border-bottom: none;
    font-size: 13px;
}
QTabBar::tab:selected { background-color: #1565c0; color: white; }
QLineEdit {
    border: 2px solid #b0bec5;
    border-radius: 5px;
    padding: 5px;
    font-size: 13px;
    background-color: white;
    min-height: 28px;
}
QLineEdit:focus { border: 2px solid #1565c0; }
QSpinBox, QDoubleSpinBox {
    border: 2px solid #b0bec5;
    border-radius: 5px;
    padding: 5px;
    font-size: 13px;
    background-color: white;
    min-height: 28px;
}
QComboBox {
    border: 2px solid #b0bec5;
    border-radius: 5px;
    padding: 5px;
    font-size: 13px;
    background-color: white;
    min-height: 28px;
}
QLabel { font-size: 12px; color: #37474f; }</string>
