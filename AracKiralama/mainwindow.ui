QPushButton#btnCikis:hover { background-color: #b71c1c; }
QPushButton#btnKartKaydet { background-color: #2e7d32; }
QPushButton#btnKartKaydet:hover { background-color: #1b5e20; }
QTableWidget {
    border: 1px solid #bbdefb;
    gridline-color: #e3f2fd;
    background-color: white;
    selection-background-color: #bbdefb;
}
QTableWidget::item { padding: 5px; }
QHeaderView::section {
    background-color: #1565c0;
    color: white;
    padding: 6px;
    font-weight: bold;
    border: none;
}
QTabWidget::pane { border: 1px solid #bbdefb; background-color: white; }
QTabBar::tab {
    background-color: #e3f2fd;
    color: #1565c0;
    padding: 8px 16px;
    font-weight: bold;
    border: 1px solid #bbdefb;
    border-bottom: none;
}
QTabBar::tab:selected { background-color: #1565c0; color: white; }
QDateEdit, QLineEdit {
    border: 2px solid #bbdefb;
    border-radius: 5px;
    padding: 5px;
    font-size: 13px;
    background-color: white;
    min-height: 28px;
}
QLineEdit:focus { border: 2px solid #1565c0; }
QLabel { font-size: 12px; color: #37474f; }</string>
